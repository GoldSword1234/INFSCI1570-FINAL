<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1><%= title %></h1>
  <p><a href="/plans">Back to plans</a></p>
  <form method="post" action="/plans">
    <label>Name<input name="name" required></label>
    <label>Goal<input name="goal"></label>
    <label>Level<select name="level"><option value="beginner">Beginner</option><option value="intermediate" selected>Intermediate</option><option value="advanced">Advanced</option></select></label>
    <label>Days per week<input name="daysPerWeek" type="number" min="1" max="7" value="3"></label>
    <label>Notes<textarea name="notes" rows="4"></textarea></label>
    <button type="submit">Create Plan</button>
  </form>
</body>
</html>
