<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1><%= plan.name %></h1>
  <p><a href="/plans">Back to plans</a></p>
  <p><strong>Goal:</strong> <%= plan.goal || '–' %></p>
  <p><strong>Level:</strong> <%= plan.level %></p>
  <p><strong>Days per week:</strong> <%= plan.daysPerWeek %></p>
  <p><strong>Notes:</strong> <%= plan.notes || 'None' %></p>

  <% if (plan.days.length) { %>
    <h2>Days</h2>
    <% plan.days.forEach(day => { %>
      <section>
        <h3><%= day.dayNumber %>. <%= day.name %></h3>
        <table>
          <thead><tr><th>Exercise</th><th>Sets</th><th>Reps</th></tr></thead>
          <tbody>
            <% day.exercises.forEach(item => { %>
              <tr>
                <td><%= item.exercise?.name || 'Unknown' %></td>
                <td><%= item.sets %></td>
                <td><%= item.reps %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    <% }) %>
  <% } %>
</body>
</html>
