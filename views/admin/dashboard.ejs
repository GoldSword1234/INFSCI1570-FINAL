<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <div class="header-row">
      <h1>Admin Dashboard</h1>
      <div class="header-actions">
        <a href="/dashboard" class="auth-button">Back to Dashboard</a>
      </div>
    </div>
    <section>
      <h2>Statistics</h2>
      <ul>
        <li>Users: <%= stats.userCount %></li>
        <li>Workouts: <%= stats.workoutCount %></li>
        <li>Exercises: <%= stats.exerciseCount %></li>
        <li>Plans: <%= stats.planCount %></li>
      </ul>
    </section>
    <section>
      <h2>Recent users</h2>
      <table>
        <thead><tr><th>Username</th><th>Email</th><th>Joined</th></tr></thead>
        <tbody>
          <% recentUsers.forEach(user => { %>
            <tr><td><%= user.username %></td><td><%= user.email %></td><td><%= user.createdAt.toDateString() %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</body>
</html>
