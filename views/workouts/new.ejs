<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <div class="header-row">
      <h1><%= title %></h1>
      <div class="header-actions">
        <a href="/workouts" class="auth-button">Back to workouts</a>
      </div>
    </div>
    <form method="post" action="/workouts">
      <div class="field">
        <label>Name</label>
        <input name="name" required>
      </div>
      <div class="field">
        <label>Goal</label>
        <input name="goal">
      </div>
      <div class="field">
        <label>Duration (minutes)</label>
        <input name="duration" type="number" min="0">
      </div>
      <div class="field">
        <label>Notes</label>
        <textarea name="notes" rows="4"></textarea>
      </div>
      <button type="submit">Save Workout</button>
    </form>
  </div>
</body>
</html>
