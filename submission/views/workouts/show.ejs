<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <div class="header-row">
      <h1><%= workout.name %></h1>
      <div class="header-actions">
        <a href="/workouts" class="auth-button">Back to workouts</a>
      </div>
    </div>
    <p><strong>Goal:</strong> <%= workout.goal || '–' %></p>
    <p><strong>Duration:</strong> <%= workout.duration %> minutes</p>
    <p><strong>Notes:</strong> <%= workout.notes || 'None' %></p>
    <% if (workout.exercises.length) { %>
      <h2>Exercises</h2>
      <table>
        <thead><tr><th>Exercise</th><th>Sets</th><th>Reps</th><th>Weight</th></tr></thead>
        <tbody>
          <% workout.exercises.forEach(item => { %>
            <tr>
              <td><%= item.exercise?.name || 'Unknown' %></td>
              <td><%= item.sets %></td>
              <td><%= item.reps %></td>
              <td><%= item.weightLbs %> lbs</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
    <div class="actions">
      <a href="/workouts/<%= workout._id %>/edit">Edit workout</a>
    </div>
  </div>
</body>
</html>
